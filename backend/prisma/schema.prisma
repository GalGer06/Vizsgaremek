generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model feladatok {
  id        Int      @id @default(autoincrement())
  title     String
  question  String
  answers   String   @db.LongText
  correct   String
  funfact   String
  createdAt DateTime @default(now())
}

model friend {
  id                         Int      @id @default(autoincrement())
  userId                     Int
  friendId                   Int
  createdAt                  DateTime @default(now())
  user_friend_friendIdTouser user     @relation("friend_friendIdTouser", fields: [friendId], references: [id], map: "Friend_friendId_fkey")
  user_friend_userIdTouser   user     @relation("friend_userIdTouser", fields: [userId], references: [id], map: "Friend_userId_fkey")

  @@unique([userId, friendId], map: "Friend_userId_friendId_key")
  @@index([friendId], map: "Friend_friendId_fkey")
}

model friendrequest {
  id                                   Int      @id @default(autoincrement())
  requesterId                          Int
  receiverId                           Int
  createdAt                            DateTime @default(now())
  user_friendrequest_receiverIdTouser  user     @relation("friendrequest_receiverIdTouser", fields: [receiverId], references: [id], map: "FriendRequest_receiverId_fkey")
  user_friendrequest_requesterIdTouser user     @relation("friendrequest_requesterIdTouser", fields: [requesterId], references: [id], map: "FriendRequest_requesterId_fkey")

  @@unique([requesterId, receiverId], map: "FriendRequest_requesterId_receiverId_key")
  @@index([receiverId], map: "FriendRequest_receiverId_fkey")
}

model ticket {
  id          Int           @id @default(autoincrement())
  userId      Int
  type        ticket_type
  description String        @db.Text
  attachment  String?       @db.LongText
  status      ticket_status @default(OPEN)
  createdAt   DateTime      @default(now())
  user        user          @relation(fields: [userId], references: [id], map: "Ticket_userId_fkey")

  @@index([userId], map: "Ticket_userId_fkey")
}

model user {
  id                                            Int             @id @default(autoincrement())
  name                                          String
  email                                         String          @unique(map: "User_email_key")
  password                                      String
  access                                        Boolean         @default(false)
  createdAt                                     DateTime        @default(now())
  username                                      String          @unique(map: "User_username_key")
  friend_friend_friendIdTouser                  friend[]        @relation("friend_friendIdTouser")
  friend_friend_userIdTouser                    friend[]        @relation("friend_userIdTouser")
  friendrequest_friendrequest_receiverIdTouser  friendrequest[] @relation("friendrequest_receiverIdTouser")
  friendrequest_friendrequest_requesterIdTouser friendrequest[] @relation("friendrequest_requesterIdTouser")
  ticket                                        ticket[]
  userdatas                                     userdatas[]
}

model useranswer {
  id             Int      @id @default(autoincrement())
  userId         Int
  questionId     Int
  isCorrect      Boolean
  createdAt      DateTime @default(now())
  selectedAnswer String?

  @@unique([userId, questionId], map: "UserAnswer_userId_questionId_key")
}

model userdatas {
  id               Int     @id @default(autoincrement())
  userId           Int     @unique
  streak           Int     @default(0)
  totalPoints      Int     @default(0)
  level            Int     @default(1)
  adminBonusPoints Int     @default(0)
  dailyBonusPoints Int     @default(0)
  user             user    @relation(fields: [userId], references: [id], map: "UserDatas_userId_fkey")
  achievements     user_achievement[]

  @@index([userId], map: "UserDatas_userId_fkey")
}

model achievement {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String?
  users       user_achievement[]
}

model home_button {
  id        Int      @id @default(autoincrement())
  label     String
  link      String
  image     String
  order     Int      @default(0)
}

model topic {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  icon      String
  image     String?
}

model user_achievement {
  id            Int         @id @default(autoincrement())
  userDataId    Int
  achievementId Int
  completed     Boolean     @default(false)
  createdAt     DateTime    @default(now())

  userData      userdatas   @relation(fields: [userDataId], references: [id])
  achievement   achievement @relation(fields: [achievementId], references: [id])

  @@unique([userDataId, achievementId])
}

enum ticket_type {
  BUG
  SUGGEST_QUESTION
}

enum ticket_status {
  OPEN
  CLOSED
}
